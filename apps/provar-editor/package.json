{
	"name": "provar-editor",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app for Provar test editing",
	"scripts": {
		"dev": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"start": "vite build && electrobun dev",
		"build": "vite build && electrobun build",
		"lint": "prettier --check src",
		"lint:fix": "prettier --write src"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.21.1",
		"electrobun": "1.18.1",
		"lucide-svelte": "^0.474.0",
		"pixi.js": "^8.18.1",
		"yaml": "^2.7.0",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tailwindcss/vite": "^4.0.0",
		"@types/bun": "latest",
		"concurrently": "^9.1.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.16.1",
		"svelte-check": "^4.1.1",
		"tailwindcss": "^4.0.0",
		"typescript": "^6",
		"vite": "^6.0.3"
	}
}
