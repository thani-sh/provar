{
  "name": "@apps/provar-app",
  "type": "module",
  "version": "1.0.0",
  "description": "Electrobun app for Provar test editing",
  "scripts": {
    "dev": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "start": "vite build && electrobun dev",
    "build": "vite build && electrobun build",
    "lint": "prettier --check src",
    "lint:fix": "prettier --write src"
  },
  "dependencies": {
    "@libs/config": "workspace:*",
    "@libs/domain": "workspace:*",
    "@libs/engine": "workspace:*",
    "@libs/models": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@thani-sh/steam-bun": "^1.0.5",
    "electrobun": "1.18.1",
    "lucide-svelte": "^0.474.0",
    "pixi.js": "^8.18.1",
    "playwright": "^1.60.0",
    "playwright-core": "^1.60.0",
    "yaml": "^2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "chromium-bidi": "^0.8.1",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.0",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
