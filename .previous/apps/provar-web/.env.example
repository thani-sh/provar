# Apps/provar-web — local dev overrides for build-info.ts.
# Copy to .env and adjust. Never commit .env.

# Set to "true" once the provar.se/install.sh endpoint is live. Until then the home page
# shows a "coming soon" card and the /docs/install page recommends the manual steps.
PUBLIC_INSTALL_LIVE=false

# Override the GitHub repo link from the default.
# PUBLIC_GITHUB_REPO=https://github.com/thani-sh/provar

# Override the install base URL (used in the curl install line when PUBLIC_INSTALL_LIVE=true).
# PUBLIC_INSTALL_BASE=https://provar.se

# Override the download artifact base (advanced; usually empty so links go directly to
# the GitHub releases page).
# PUBLIC_DOWNLOAD_BASE=
