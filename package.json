{
  "name": "provar",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "AI agentic tool to create end-to-end tests",
  "workspaces": ["apps/*", "libs/*", "demo/*"],
  "scripts": {
    "provar": "bun run ./apps/provar-cli/src/index.ts",
    "dev": "bun --filter '*' dev",
    "lint": "bun --filter '*' lint",
    "lint:fix": "bun --filter '*' lint:fix"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:aivara-se/provar.se.git"
  },
  "dependencies": {
    "@libs/executor": "workspace:*",
    "@libs/compiler": "workspace:*",
    "@apps/provar-cli": "workspace:*",
    "js-yaml": "^4.1.1",
    "picocolors": "^1.1.1"
  }
}
